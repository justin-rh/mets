# Copy to .env and fill in. Server loads this from the repo root.

DATABASE_URL=postgres://mets:mets_dev@localhost:5433/mets
PORT=3001

# Adapters: which implementation each seam uses (see docs/DESIGN.md §4)
AUTH_PROVIDER=dev          # dev | entra
MAIL_PROVIDER=mock         # mock | graph
AI_PROVIDER=claude         # claude | mock
STORAGE_PROVIDER=local     # local | azure-blob

# AI (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
AI_DAILY_TOKEN_BUDGET=2000000
